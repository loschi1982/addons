<svg xmlns="http://www.w3.org/2000/svg" width="192" height="192" viewBox="0 0 192 192">
  <!-- Hintergrund -->
  <rect width="192" height="192" rx="36" fill="#0f0f0f"/>

  <!-- Äußerer Rahmen (AR-Kamera-Symbolik) -->
  <rect x="20" y="20" width="152" height="152" rx="16"
        fill="none" stroke="#4a9eff" stroke-width="6"/>

  <!-- Kamera-Linse (Kreis) -->
  <circle cx="96" cy="96" r="38" fill="none" stroke="#4a9eff" stroke-width="6"/>
  <circle cx="96" cy="96" r="20" fill="#4a9eff" opacity="0.25"/>

  <!-- QR-Ecken oben links -->
  <path d="M20 52 L20 20 L52 20" fill="none" stroke="#ffffff" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
  <!-- QR-Ecken oben rechts -->
  <path d="M140 20 L172 20 L172 52" fill="none" stroke="#ffffff" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
  <!-- QR-Ecken unten links -->
  <path d="M20 140 L20 172 L52 172" fill="none" stroke="#ffffff" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
  <!-- QR-Ecken unten rechts -->
  <path d="M140 172 L172 172 L172 140" fill="none" stroke="#ffffff" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
</svg>