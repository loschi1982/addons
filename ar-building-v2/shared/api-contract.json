{
  "_comment": "Dieser Vertrag definiert alle API-Endpunkte. Alle Teams richten sich danach.",
  "_version": "2.1.2",
  "_changelog": {
    "2.1.2": "HTTPS-Port konfigurierbar (Standard 8444), apiBase nutzt window.location.origin",
    "2.1.1": "Rate Limiting (429), Upload-Validierung (413/400), Ingress-Port dokumentiert",
    "2.1.0": "PlanRadar v2: marker_id-Logik, Journals, Attachments, Kommentare, planradar_customer_id",
    "2.0.0": "Initiale Version"
  },
  "_base_url_https": "https://<host>:<https_port> (Standard 8444, konfigurierbar)",
  "_base_url_ingress": "/api/hassio_ingress/<token>",
  "_ingress_port": 8099,
  "_note": "JWT als Bearer-Token im Authorization-Header. Rollen: visitor < staff < technician < admin.",

  "auth": {
    "POST /api/auth/login": {
      "description": "Login mit Benutzername + PIN oder Visitor-Token",
      "auth": "none",
      "rate_limit": "max. 5 Fehlversuche pro Username in 60 Sekunden",
      "request": {
        "type": "object",
        "oneOf": [
          {
            "description": "PIN-Login (Personal, Techniker, Admin)",
            "properties": {
              "username": { "type": "string" },
              "pin":      { "type": "string", "minLength": 4, "maxLength": 4 }
            },
            "required": ["username", "pin"]
          },
          {
            "description": "Visitor-QR-Token-Login",
            "properties": {
              "token": { "type": "string", "example": "login:visitor-abc123" }
            },
            "required": ["token"]
          }
        ]
      },
      "response_200": {
        "jwt":      { "type": "string", "description": "JWT, 12h gültig (konfigurierbar)" },
        "role":     { "type": "string", "enum": ["visitor", "staff", "technician", "admin"] },
        "username": { "type": "string" }
      },
      "response_401": { "detail": "Invalid credentials" },
      "response_429": { "detail": "Zu viele Fehlversuche. Bitte 60 Sekunden warten." }
    },

    "GET /api/auth/visitor-token": {
      "description": "Generiert einen neuen Visitor-QR-Token (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "response_200": {
        "token":      { "type": "string", "example": "login:visitor-abc123" },
        "qr_content": { "type": "string", "example": "login:visitor-abc123" }
      }
    }
  },

  "rooms": {
    "GET /api/rooms": {
      "description": "Alle Räume auflisten",
      "auth": "Bearer JWT (any role)",
      "response_200": { "type": "array", "items": { "$ref": "#/schemas/RoomSummary" } }
    },

    "GET /api/rooms/{room_id}": {
      "description": "Einzelnen Raum mit allen Details laden",
      "auth": "Bearer JWT (any role)",
      "response_200": { "$ref": "#/schemas/RoomDetail" },
      "response_404": { "detail": "Room not found" }
    },

    "GET /api/rooms/by-marker/{marker_id}": {
      "description": "Raum per QR-Marker-ID laden (z.B. 'room:1')",
      "auth": "Bearer JWT (any role)",
      "response_200": { "$ref": "#/schemas/RoomDetail" },
      "response_404": { "detail": "Room not found" }
    },

    "POST /api/rooms": {
      "description": "Neuen Raum anlegen (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "request": { "$ref": "#/schemas/RoomCreate" },
      "response_201": { "$ref": "#/schemas/RoomDetail" }
    },

    "PUT /api/rooms/{room_id}": {
      "description": "Raum bearbeiten (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "request": { "$ref": "#/schemas/RoomCreate" },
      "response_200": { "$ref": "#/schemas/RoomDetail" },
      "response_404": { "detail": "Room not found" }
    },

    "DELETE /api/rooms/{room_id}": {
      "description": "Raum löschen (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "response_204": {},
      "response_404": { "detail": "Room not found" }
    },

    "POST /api/rooms/{room_id}/files": {
      "description": "Datei-Upload für Raum (ONNX-Modell, Audio, Video)",
      "auth": "Bearer JWT (role=admin)",
      "request": "multipart/form-data: file, file_type ('model'|'audio'|'video')",
      "upload_limits": {
        "model": { "extensions": [".onnx"], "max_mb": 50 },
        "audio": { "extensions": [".mp3", ".wav", ".ogg", ".m4a"], "max_mb": 20 },
        "video": { "extensions": [".mp4", ".webm", ".mov"], "max_mb": 200 }
      },
      "response_200": { "path": { "type": "string", "example": "/uploads/1/model.onnx" } },
      "response_400": "Ungültiger Dateiname oder nicht erlaubte Dateiendung",
      "response_413": "Datei zu groß"
    }
  },

  "objects": {
    "GET /api/objects": {
      "description": "Alle Objekte/Exponate auflisten",
      "auth": "Bearer JWT (any role)",
      "query": { "room_id": "optional int – filtert nach Raum" },
      "response_200": { "type": "array", "items": { "$ref": "#/schemas/ObjectSummary" } }
    },

    "GET /api/objects/{object_id}": {
      "description": "Einzelnes Objekt mit Details",
      "auth": "Bearer JWT (any role)",
      "response_200": { "$ref": "#/schemas/ObjectDetail" },
      "response_404": { "detail": "Object not found" }
    },

    "GET /api/objects/by-marker/{marker_id}": {
      "description": "Objekt per QR-Marker laden (z.B. 'object:42')",
      "auth": "Bearer JWT (any role)",
      "response_200": { "$ref": "#/schemas/ObjectDetail" },
      "response_404": { "detail": "Object not found" }
    },

    "POST /api/objects": {
      "description": "Neues Objekt anlegen (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "request": { "$ref": "#/schemas/ObjectCreate" },
      "response_201": { "$ref": "#/schemas/ObjectDetail" }
    },

    "PUT /api/objects/{object_id}": {
      "description": "Objekt bearbeiten (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "request": { "$ref": "#/schemas/ObjectCreate" },
      "response_200": { "$ref": "#/schemas/ObjectDetail" }
    },

    "DELETE /api/objects/{object_id}": {
      "description": "Objekt löschen (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "response_204": {}
    }
  },

  "object_types": {
    "GET /api/object-types": {
      "description": "Alle konfigurierten Objekttypen",
      "auth": "Bearer JWT (any role)",
      "response_200": { "type": "array", "items": { "$ref": "#/schemas/ObjectType" } }
    },
    "POST /api/object-types": {
      "description": "Neuen Objekttyp anlegen (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "request": { "$ref": "#/schemas/ObjectTypeCreate" },
      "response_201": { "$ref": "#/schemas/ObjectType" }
    },
    "PUT /api/object-types/{type_id}": {
      "description": "Objekttyp bearbeiten (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "request": { "$ref": "#/schemas/ObjectTypeCreate" },
      "response_200": { "$ref": "#/schemas/ObjectType" }
    },
    "DELETE /api/object-types/{type_id}": {
      "description": "Objekttyp löschen (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "response_204": {}
    }
  },

  "users": {
    "GET /api/users": {
      "description": "Alle Benutzer (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "response_200": { "type": "array", "items": { "$ref": "#/schemas/UserSummary" } }
    },
    "POST /api/users": {
      "description": "Benutzer anlegen (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "request": { "$ref": "#/schemas/UserCreate" },
      "response_201": { "$ref": "#/schemas/UserSummary" }
    },
    "PUT /api/users/{user_id}": {
      "description": "Benutzer bearbeiten (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "request": { "$ref": "#/schemas/UserCreate" },
      "response_200": { "$ref": "#/schemas/UserSummary" }
    },
    "DELETE /api/users/{user_id}": {
      "description": "Benutzer löschen (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "response_204": {}
    }
  },

  "statistics": {
    "POST /api/stats/event": {
      "description": "Ein Tracking-Event speichern",
      "auth": "Bearer JWT (any role)",
      "request": { "$ref": "#/schemas/StatEvent" },
      "response_201": {}
    },
    "POST /api/stats/heartbeat": {
      "description": "Heartbeat einer aktiven Session (alle 30s vom Frontend)",
      "auth": "Bearer JWT (any role)",
      "request": {
        "session_id": { "type": "string" },
        "room_id":    { "type": "integer", "nullable": true }
      },
      "response_200": {}
    },
    "GET /api/stats/dashboard": {
      "description": "KPI-Daten für Admin-Dashboard",
      "auth": "Bearer JWT (role=admin)",
      "response_200": { "$ref": "#/schemas/DashboardData" }
    },
    "GET /api/stats/live": {
      "description": "Live-Daten: aktive Sessions + aktive Räume (90s-Fenster)",
      "auth": "Bearer JWT (role=admin)",
      "response_200": { "$ref": "#/schemas/LiveData" }
    }
  },

  "settings": {
    "GET /api/settings": {
      "description": "Alle Einstellungen laden (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "response_200": { "$ref": "#/schemas/Settings" }
    },
    "PUT /api/settings": {
      "description": "Einstellungen speichern (nur Admin)",
      "auth": "Bearer JWT (role=admin)",
      "request": { "$ref": "#/schemas/Settings" },
      "response_200": { "$ref": "#/schemas/Settings" }
    }
  },

  "ha_sensors": {
    "GET /api/ha/sensors": {
      "description": "Alle HA-Sensoren abrufen (Proxy zu HA-API, nur sensor.*-Entitäten)",
      "auth": "Bearer JWT (any role)",
      "response_200": { "type": "array", "items": { "$ref": "#/schemas/HASensor" } },
      "response_503": "Home Assistant nicht konfiguriert oder nicht erreichbar"
    },
    "GET /api/ha/sensors/{entity_id}": {
      "description": "Einzelnen HA-Sensor abrufen (entity_id z.B. 'sensor.temperature_foyer')",
      "auth": "Bearer JWT (any role)",
      "response_200": { "$ref": "#/schemas/HASensor" },
      "response_404": { "detail": "Sensor not found" }
    }
  },

  "planradar": {
    "_note": "Alle Proxy-Endpunkte erfordern planradar_token + planradar_customer_id in /api/settings.",

    "GET /api/planradar/projects": {
      "description": "Alle PlanRadar-Projekte abrufen",
      "auth": "Bearer JWT (role=admin)",
      "response_200": { "type": "array", "items": { "$ref": "#/schemas/PlanRadarProject" } }
    },

    "GET /api/planradar/projects/{project_id}/list-fields": {
      "description": "Listenfelder eines Projekts – liefert field_key (typed-values-Key), list_id, field_label",
      "auth": "Bearer JWT (role=admin)",
      "response_200": {
        "type": "array",
        "items": {
          "field_key":   { "type": "string", "example": "tf37e04757dabbca63" },
          "list_id":     { "type": "string" },
          "field_label": { "type": "string" }
        }
      }
    },

    "GET /api/planradar/lists": {
      "description": "Custom-Listen eines Projekts",
      "auth": "Bearer JWT (role=admin)",
      "query": { "project_id": "optional string" },
      "response_200": { "type": "array", "items": { "$ref": "#/schemas/PlanRadarList" } }
    },

    "GET /api/planradar/lists/{list_id}/entries": {
      "description": "Einträge einer PlanRadar-Liste (z.B. einzelne Räume oder Anlagen)",
      "auth": "Bearer JWT (role=admin)",
      "response_200": { "type": "array", "items": { "$ref": "#/schemas/PlanRadarListEntry" } }
    },

    "GET /api/planradar/project-roles": {
      "description": "Rollenzuordnungen für PlanRadar-Projekte laden",
      "auth": "Bearer JWT (role=admin)",
      "response_200": { "type": "array", "items": { "$ref": "#/schemas/PlanRadarProjectRole" } }
    },

    "PUT /api/planradar/project-roles": {
      "description": "Rollenzuordnungen speichern (Upsert per project_id)",
      "auth": "Bearer JWT (role=admin)",
      "request": { "type": "array", "items": { "$ref": "#/schemas/PlanRadarProjectRole" } },
      "response_200": { "type": "array", "items": { "$ref": "#/schemas/PlanRadarProjectRole" } }
    },

    "GET /api/planradar/mappings": {
      "description": "Alle gespeicherten Marker-Mappings laden (AR-Marker ↔ PlanRadar-Eintrag)",
      "auth": "Bearer JWT (role=admin)",
      "response_200": { "type": "array", "items": { "$ref": "#/schemas/PlanRadarMapping" } }
    },

    "POST /api/planradar/mappings": {
      "description": "Marker-Mapping anlegen oder aktualisieren (Upsert per ar_marker_id)",
      "auth": "Bearer JWT (role=admin)",
      "request": { "$ref": "#/schemas/PlanRadarMappingCreate" },
      "response_201": { "$ref": "#/schemas/PlanRadarMapping" }
    },

    "DELETE /api/planradar/mappings/{mapping_id}": {
      "description": "Marker-Mapping löschen",
      "auth": "Bearer JWT (role=admin)",
      "response_204": {},
      "response_404": { "detail": "Mapping not found" }
    },

    "GET /api/planradar/tickets": {
      "description": "PlanRadar-Tickets laden. Bei marker_id: Mapping nachschlagen + Rollencheck + Listeneintrag-Filter. Bei room_id/object_id: Legacy-Logik.",
      "auth": "Bearer JWT (role=staff|technician|admin)",
      "query": {
        "marker_id": "optional string – bevorzugte Methode (v2.1.0+)",
        "room_id":   "optional int – Legacy",
        "object_id": "optional int – Legacy"
      },
      "response_200": { "type": "array", "items": { "$ref": "#/schemas/PlanRadarTicket" } }
    },

    "PUT /api/planradar/tickets/{ticket_id}/status": {
      "description": "Ticketstatus setzen. project_id aus Query-Parameter oder In-Memory-Cache.",
      "auth": "Bearer JWT (role=technician|admin)",
      "query": { "project_id": "optional string" },
      "request": {
        "status": { "type": "string", "enum": ["open", "in_progress", "resolved", "feedback", "closed", "rejected"] }
      },
      "response_200": { "$ref": "#/schemas/PlanRadarTicket" },
      "response_400": "Ungültiger Status oder project_id unbekannt"
    },

    "GET /api/planradar/tickets/{ticket_id}/journals": {
      "description": "Journals (Kommentare, Medien, Änderungshistorie) eines Tickets",
      "auth": "Bearer JWT (role=staff|technician|admin)",
      "query": {
        "project_id": "optional string",
        "filter": "optional string – 1=Kommentare, 2=Medien, 3=Änderungshistorie"
      },
      "response_200": { "type": "array", "items": { "$ref": "#/schemas/PlanRadarJournal" } }
    },

    "GET /api/planradar/tickets/{ticket_id}/attachments": {
      "description": "Attachments (Bilder, Dokumente, Audio, Video) eines Tickets",
      "auth": "Bearer JWT (role=staff|technician|admin)",
      "query": {
        "project_id": "optional string",
        "types": "optional string – kommagetrennt: images,audios,videos,documents"
      },
      "response_200": { "type": "array", "items": { "$ref": "#/schemas/PlanRadarAttachment" } }
    },

    "POST /api/planradar/tickets/{ticket_id}/comment": {
      "description": "Kommentar zu einem Ticket hinzufügen (via Ticket-PUT mit notes-Feld)",
      "auth": "Bearer JWT (role=staff|technician|admin)",
      "query": { "project_id": "optional string" },
      "request": { "comment": { "type": "string" } },
      "response_201": { "$ref": "#/schemas/PlanRadarTicket" },
      "response_400": "Kommentartext fehlt oder project_id unbekannt"
    }
  },

  "static": {
    "GET /":                             "frontend/index.html (PWA)",
    "GET /admin":                        "admin/index.html (Admin-UI, dynamisch – injiziert X-Ingress-Path als apiBase)",
    "GET /uploads/{room_id}/{filename}": "Hochgeladene Raumdateien (ONNX, Audio, Video)",
    "GET /assets/*":                     "Frontend-Assets (Bilder, SVG)",
    "GET /css/*":                        "Frontend-CSS",
    "GET /js/*":                         "Frontend-JS",
    "GET /admin-static/*":              "Admin-UI-Assets (CSS, JS)"
  },

  "schemas": {
    "RoomSummary": {
      "id":         { "type": "integer" },
      "name":       { "type": "string" },
      "marker_id":  { "type": "string", "example": "room:1" },
      "short_desc": { "type": "string" }
    },

    "RoomDetail": {
      "id":            { "type": "integer" },
      "name":          { "type": "string" },
      "marker_id":     { "type": "string" },
      "short_desc":    { "type": "string" },
      "detail_text":   { "type": "string", "description": "HTML vom WYSIWYG-Editor" },
      "model_path":    { "type": "string", "nullable": true },
      "audio_path":    { "type": "string", "nullable": true },
      "video_path":    { "type": "string", "nullable": true },
      "video_opacity": { "type": "number", "minimum": 0, "maximum": 1 },
      "ha_sensor_ids": { "type": "array", "items": { "type": "string" } },
      "objects":       { "type": "array", "items": { "$ref": "#/schemas/ObjectSummary" } }
    },

    "RoomCreate": {
      "name":          { "type": "string" },
      "marker_id":     { "type": "string" },
      "short_desc":    { "type": "string" },
      "detail_text":   { "type": "string" },
      "video_opacity": { "type": "number", "default": 0.8 },
      "ha_sensor_ids": { "type": "array", "items": { "type": "string" } }
    },

    "ObjectSummary": {
      "id":         { "type": "integer" },
      "name":       { "type": "string" },
      "marker_id":  { "type": "string", "example": "object:42" },
      "short_desc": { "type": "string" },
      "type_id":    { "type": "integer" },
      "type_name":  { "type": "string" },
      "room_id":    { "type": "integer" }
    },

    "ObjectDetail": {
      "id":            { "type": "integer" },
      "name":          { "type": "string" },
      "marker_id":     { "type": "string" },
      "short_desc":    { "type": "string" },
      "detail_text":   { "type": "string" },
      "type_id":       { "type": "integer" },
      "type_name":     { "type": "string" },
      "room_id":       { "type": "integer" },
      "video_path":    { "type": "string", "nullable": true },
      "video_opacity": { "type": "number" },
      "audio_path":    { "type": "string", "nullable": true },
      "ha_sensor_ids": { "type": "array", "items": { "type": "string" } },
      "onnx_class_id": { "type": "integer", "nullable": true, "description": "ONNX-Klassen-ID im Raummodell" }
    },

    "ObjectCreate": {
      "name":          { "type": "string" },
      "marker_id":     { "type": "string" },
      "short_desc":    { "type": "string" },
      "detail_text":   { "type": "string" },
      "type_id":       { "type": "integer" },
      "room_id":       { "type": "integer" },
      "video_path":    { "type": "string", "nullable": true },
      "video_opacity": { "type": "number", "default": 0.8 },
      "audio_path":    { "type": "string", "nullable": true },
      "ha_sensor_ids": { "type": "array", "items": { "type": "string" } },
      "onnx_class_id": { "type": "integer", "nullable": true }
    },

    "ObjectType": {
      "id":               { "type": "integer" },
      "name":             { "type": "string", "example": "Exponat" },
      "visible_to_roles": { "type": "array", "items": { "type": "string", "enum": ["visitor","staff","technician","admin"] } }
    },

    "ObjectTypeCreate": {
      "name":             { "type": "string" },
      "visible_to_roles": { "type": "array", "items": { "type": "string" } }
    },

    "UserSummary": {
      "id":       { "type": "integer" },
      "username": { "type": "string" },
      "role":     { "type": "string", "enum": ["visitor", "staff", "technician", "admin"] }
    },

    "UserCreate": {
      "username": { "type": "string" },
      "pin":      { "type": "string", "minLength": 4, "maxLength": 4 },
      "role":     { "type": "string", "enum": ["staff", "technician", "admin"] }
    },

    "StatEvent": {
      "event_type": { "type": "string", "enum": ["login_pin","login_visitor","login_failed","room_scan","object_detected","detail_opened","session_end"] },
      "session_id": { "type": "string" },
      "role":       { "type": "string", "nullable": true },
      "room_id":    { "type": "integer", "nullable": true },
      "object_id":  { "type": "integer", "nullable": true },
      "timestamp":  { "type": "string", "format": "datetime" }
    },

    "DashboardData": {
      "total_sessions_today":     { "type": "integer" },
      "total_room_scans_today":   { "type": "integer" },
      "total_object_scans_today": { "type": "integer" },
      "active_sessions_now":      { "type": "integer" },
      "login_breakdown":          { "description": "{ pin: N, visitor: N, failed: N }" },
      "hourly_events":            { "type": "array", "description": "[{ hour, count }]" },
      "top_rooms":                { "type": "array", "description": "[{ room_id, name, scans }]" },
      "top_objects":              { "type": "array", "description": "[{ object_id, name, detections }]" }
    },

    "LiveData": {
      "active_sessions": { "type": "object", "description": "{ visitor: N, staff: N, technician: N, admin: N }" },
      "active_rooms":    { "type": "array",  "description": "[{ room_id, room_name, visitor_count }]" }
    },

    "Settings": {
      "ha_url":                 { "type": "string", "description": "Home Assistant URL, z.B. http://homeassistant:8123" },
      "ha_token":               { "type": "string", "description": "HA Long-Lived Access Token" },
      "planradar_token":        { "type": "string", "description": "PlanRadar API-Key" },
      "planradar_customer_id":  { "type": "string", "description": "PlanRadar Customer-ID (seit v2.1.0)" },
      "jwt_secret":             { "type": "string", "description": "JWT-Signierungsschlüssel (auto-generiert)" },
      "jwt_expire_hours":       { "type": "integer", "default": 12 }
    },

    "HASensor": {
      "entity_id":    { "type": "string", "example": "sensor.temperature_foyer" },
      "state":        { "type": "string" },
      "unit":         { "type": "string", "nullable": true },
      "friendly_name": { "type": "string" }
    },

    "PlanRadarProject": {
      "id":     { "type": "string" },
      "name":   { "type": "string" },
      "active": { "type": "boolean" }
    },

    "PlanRadarList": {
      "id":   { "type": "string" },
      "name": { "type": "string" }
    },

    "PlanRadarListEntry": {
      "uuid": { "type": "string" },
      "name": { "type": "string" }
    },

    "PlanRadarProjectRole": {
      "project_id":        { "type": "string" },
      "visible_to_roles":  { "type": "array", "items": { "type": "string", "enum": ["visitor","staff","technician","admin"] } }
    },

    "PlanRadarMappingCreate": {
