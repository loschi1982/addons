# ===========================================================================
# Umgebungsvariablen – Energy Management ISO 50001 (Standalone)
# ===========================================================================
# Kopieren: cp .env.example .env
# Dann Werte anpassen und starten: docker compose up -d
# ===========================================================================

# ── Datenbank (TimescaleDB) ──
DB_NAME=energy_management
DB_USER=energy
DB_PASSWORD=energy
# DB_PORT_EXTERNAL=5432          # Port auf dem Host (Standard: 5432)

# ── App ──
APP_PORT=8099                     # Web-Oberflaeche Port
SECRET_KEY=CHANGE-ME-use-a-random-64-char-hex-string
LOG_LEVEL=info                    # debug, info, warning, error
LANGUAGE=de                       # de, en

# ── Home Assistant Integration (optional) ──
# Long-Lived Access Token aus HA: Profil → Langlebige Zugriffstoken
HA_ACCESS_TOKEN=
# URL der HA-Instanz (z.B. http://192.168.1.100:8123)
HA_BASE_URL=
# HA-Benutzer automatisch anlegen?
HA_AUTH_ENABLED=false
HA_DEFAULT_ROLE=viewer

# ── Externe APIs ──
ELECTRICITY_MAPS_API_KEY=
BRIGHT_SKY_ENABLED=true
